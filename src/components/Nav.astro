---
import Wordmark from './Wordmark.astro';

export interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const links = [
  { id: 'browse',      label: 'Browse',      href: '/' },
  { id: 'collections', label: 'Collections', href: '/collections/' },
  { id: 'connections', label: 'Connections', href: '/connections/' },
  { id: 'about',       label: 'About',       href: '/about/' },
];

/* Map legacy `currentPage` values from the previous nav to the new ids */
const aliasMap: Record<string, string> = {
  concepts: 'browse',
  browse: 'browse',
  collections: 'collections',
  connections: 'connections',
  about: 'about',
};
const activeId = aliasMap[currentPage] ?? '';
---
<nav class="ms-nav" aria-label="Primary">
  <div class="ms-nav-inner">
    <Wordmark size="sm" />
    <ul class="ms-nav-links">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['ms-nav-link', { active: link.id === activeId }]}
            aria-current={link.id === activeId ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .ms-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--ms-paper);
    border-bottom: var(--ms-rule-width) solid var(--ms-rule);
  }

  .ms-nav-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ms-r5);
  }

  .ms-nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: var(--ms-r5);
  }

  .ms-nav-link {
    font-family: var(--ms-font-ui);
    font-size: 13px;
    font-weight: 500;
    color: var(--ms-ink);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .ms-nav-link:hover {
    color: var(--ms-coral);
  }

  .ms-nav-link.active {
    border-bottom-color: var(--ms-coral);
  }

  @media (max-width: 640px) {
    .ms-nav-inner {
      padding: 0.625rem 1rem;
      gap: var(--ms-r3);
      flex-wrap: wrap;
    }
    .ms-nav-links {
      gap: var(--ms-r4);
    }
    .ms-nav-link {
      font-size: 12px;
    }
  }

  @media (max-width: 380px) {
    .ms-nav-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--ms-r3);
    }
  }
</style>
