---
import { brandColours, diagramColours } from '../../data/categoryColours.js';

const pos = diagramColours.positive;
const posDark = diagramColours.positiveDark;
const neg = diagramColours.negative;
const negDark = diagramColours.negativeDark;
const gold = diagramColours.connection;
const goldDark = diagramColours.highlight;
const mutedFill = diagramColours.mutedFill;
const insightText = diagramColours.insightText;
---

<svg width="100%" viewBox="0 0 680 520" role="img"
  aria-label="Concept diagram explaining how the sunk cost fallacy works">
  <title>How the sunk cost fallacy works - Moresapien</title>
  <desc>A visual metaphor showing how increasing investment creates a psychological trap. The rational exit is available at every stage but feels harder to take the more you've invested. The bars widen to represent growing investment while the exit stays the same size.</desc>

  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

  <text class="th" x="340" y="32" text-anchor="middle">How sunk costs deepen the trap</text>

  <text class="ts" x="68" y="68" text-anchor="start" opacity="0.45">What you've invested</text>
  <text class="ts" x="430" y="68" text-anchor="start" opacity="0.45">The rational exit is always here</text>

  <!-- Level 1: Small investment (teal/positive) -->
  <rect x="60" y="82" width="100" height="48" rx="4" fill={pos} fill-opacity="0.08" stroke={pos} stroke-width="0.5"/>
  <text class="th" x="110" y="102" text-anchor="middle" fill={posDark}>£500</text>
  <text class="ts" x="110" y="118" text-anchor="middle" fill={posDark}>3 months</text>

  <line x1="160" y1="106" x2="408" y2="106" stroke={pos} stroke-width="0.5" opacity="0.3" stroke-dasharray="3 3"/>
  <rect x="410" y="90" width="80" height="32" rx="16" fill={pos} fill-opacity="0.1" stroke={pos} stroke-width="0.8"/>
  <text class="ts" x="450" y="110" text-anchor="middle" fill={posDark}>Easy to leave</text>

  <!-- Level 2: Medium investment (gold) -->
  <rect x="60" y="150" width="160" height="48" rx="4" fill={gold} fill-opacity="0.08" stroke={gold} stroke-width="0.5"/>
  <text class="th" x="140" y="170" text-anchor="middle" fill={goldDark}>£3,000</text>
  <text class="ts" x="140" y="186" text-anchor="middle" fill={goldDark}>1 year</text>

  <line x1="220" y1="174" x2="408" y2="174" stroke={pos} stroke-width="0.5" opacity="0.3" stroke-dasharray="3 3"/>
  <rect x="410" y="158" width="80" height="32" rx="16" fill={pos} fill-opacity="0.1" stroke={pos} stroke-width="0.8"/>
  <text class="ts" x="450" y="178" text-anchor="middle" fill={posDark}>Still the same</text>

  <!-- Level 3: Large investment (coral/negative) -->
  <rect x="60" y="218" width="240" height="48" rx="4" fill={neg} fill-opacity="0.08" stroke={neg} stroke-width="0.5"/>
  <text class="th" x="180" y="238" text-anchor="middle" fill={negDark}>£15,000</text>
  <text class="ts" x="180" y="254" text-anchor="middle" fill={negDark}>3 years</text>

  <line x1="300" y1="242" x2="408" y2="242" stroke={pos} stroke-width="0.5" opacity="0.3" stroke-dasharray="3 3"/>
  <rect x="410" y="226" width="80" height="32" rx="16" fill={pos} fill-opacity="0.1" stroke={pos} stroke-width="0.8"/>
  <text class="ts" x="450" y="246" text-anchor="middle" fill={posDark}>Still the same</text>

  <!-- Level 4: Massive investment (coral/negative, deeper) -->
  <rect x="60" y="286" width="340" height="48" rx="4" fill={neg} fill-opacity="0.12" stroke={neg} stroke-width="0.5"/>
  <text class="th" x="230" y="306" text-anchor="middle" fill={negDark}>£50,000</text>
  <text class="ts" x="230" y="322" text-anchor="middle" fill={negDark}>5 years, a whole identity</text>

  <line x1="400" y1="310" x2="408" y2="310" stroke={pos} stroke-width="0.5" opacity="0.3" stroke-dasharray="3 3"/>
  <rect x="410" y="294" width="80" height="32" rx="16" fill={pos} fill-opacity="0.1" stroke={pos} stroke-width="0.8"/>
  <text class="ts" x="450" y="314" text-anchor="middle" fill={posDark}>Still the same</text>

  <!-- Divider line -->
  <line x1="340" y1="76" x2="340" y2="340" stroke="var(--color-border-tertiary, #e8e0d8)" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.3"/>

  <!-- Emotional scale -->
  <text class="ts" x="552" y="104" opacity="0.4">↑ feels easy</text>
  <text class="ts" x="552" y="314" opacity="0.4">↓ feels impossible</text>
  <line x1="586" y1="116" x2="586" y2="298" stroke="var(--color-border-secondary, #d3d1c7)" stroke-width="0.5" opacity="0.2" marker-end="url(#arrow)"/>

  <!-- The breakthrough question -->
  <rect x="60" y="370" width="560" height="80" rx="10" fill={mutedFill} stroke="var(--color-border-tertiary, #e8e0d8)" stroke-width="0.5"/>
  <text class="th" x="340" y="400" text-anchor="middle">The question that breaks the spell</text>
  <text class="ts" x="340" y="424" text-anchor="middle" opacity="0.7">Knowing what I know now, would I start this from scratch today?</text>
  <text class="ts" x="340" y="442" text-anchor="middle" opacity="0.5">If no — the past investment is irrelevant. Only the future matters.</text>

  <!-- Closing insight -->
  <text class="ts" x="340" y="490" text-anchor="middle" fill={insightText} opacity="0.45">The money is gone. The time is gone.</text>
  <text class="ts" x="340" y="508" text-anchor="middle" fill={insightText} opacity="0.45">The only thing you can waste now is your future.</text>
</svg>
