---
import { categoryColours, brandColours } from '../data/categoryColours.js';

interface RelatedConcept {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  oneLiner: string;
  category: string;
  thoughtToHoldOnto: string;
  relatedConcepts: RelatedConcept[];
  slug: string;
}

const { title, oneLiner, category, thoughtToHoldOnto, relatedConcepts, slug } = Astro.props;

const accent = categoryColours[category] || brandColours.coral;
const related = (relatedConcepts || []).slice(0, 3);

function stripMd(s: string): string {
  return (s || '').replace(/\*(.*?)\*/g, '$1').replace(/\s+/g, ' ').trim();
}

function wrap(text: string, maxWidth: number, fontSize: number, avgChar = 0.55): string[] {
  const words = stripMd(text).split(' ');
  const maxChars = Math.floor(maxWidth / (fontSize * avgChar));
  const lines: string[] = [];
  let current = '';
  for (const word of words) {
    const next = current ? current + ' ' + word : word;
    if (next.length > maxChars && current) {
      lines.push(current);
      current = word;
    } else {
      current = next;
    }
  }
  if (current) lines.push(current);
  return lines;
}

function clipLines(lines: string[], maxLines: number): string[] {
  if (lines.length <= maxLines) return lines;
  const clipped = lines.slice(0, maxLines);
  const last = clipped[maxLines - 1];
  clipped[maxLines - 1] = last.replace(/[.,;:\s]+$/, '') + '…';
  return clipped;
}

const W = 1200;
const H = 630;
const padX = 64;
const accentBarH = 12;

const titleLines = clipLines(wrap(title, W - padX * 2, 60, 0.58), 2);
const oneLinerLines = clipLines(wrap(oneLiner, W - padX * 2, 28, 0.5), 2);
const thoughtLines = clipLines(wrap(thoughtToHoldOnto, W - padX * 2 - 80, 30, 0.55), 4);

let y = accentBarH + 50;
const badgeY = y;
y += 56;
const titleY = y;
y += 60 * titleLines.length + 14;
const oneLinerY = y;
y += 36 * oneLinerLines.length + 32;
const divider1Y = y;
y += 28;
const thoughtBoxY = y;
const thoughtBoxPadY = 28;
const thoughtLabelY = thoughtBoxY + thoughtBoxPadY + 22;
const thoughtTextY = thoughtLabelY + 36;
const thoughtBoxH = thoughtBoxPadY + 22 + 14 + 36 * thoughtLines.length + thoughtBoxPadY;
y = thoughtBoxY + thoughtBoxH + 28;
const divider2Y = y;
y += 36;
const relatedY = y;

const footerY = H - 36;
const cardId = 'kc-' + slug;

function approxWidth(text: string, fontSize: number, avgChar = 0.5): number {
  return text.length * fontSize * avgChar;
}

const dotR = 7;
const dotGap = 14;
const labelGap = 36;
let cursor = padX;
const relatedItems = related.map((r) => {
  const w = approxWidth(r.title, 22, 0.52);
  const item = { x: cursor, title: r.title, w };
  cursor += dotR * 2 + dotGap + w + labelGap;
  return item;
});

const altText = `${title} - ${category}. ${oneLiner}`;

/* Logical Fallacy needs ink text on saffron for accessibility. */
const onAccentText = category === 'Logical Fallacy' ? brandColours.ink : '#FFFFFF';
const displayFont = "'Newsreader', Georgia, serif";
const bodyFont = "'General Sans', system-ui, sans-serif";
const monoFont = "'DM Mono', ui-monospace, monospace";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${W} ${H}`}
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label={`Knowledge card: ${altText}`}
  class="knowledge-card-svg"
>
  <title>{`${title} - ${category} - Moresapien`}</title>
  <desc>{altText}</desc>

  <!-- Background -->
  <rect width={W} height={H} fill={brandColours.paper} />

  <!-- Top accent bar -->
  <rect x="0" y="0" width={W} height={accentBarH} fill={accent} />

  <!-- Category pill -->
  <g>
    {(() => {
      const labelW = approxWidth(category.toUpperCase(), 18, 0.62) + 36;
      return (
        <>
          <rect
            x={padX}
            y={badgeY}
            width={labelW}
            height={36}
            rx="18"
            ry="18"
            fill={accent}
          />
          <text
            x={padX + labelW / 2}
            y={badgeY + 24}
            font-family={monoFont}
            font-size="14"
            font-weight="500"
            fill={onAccentText}
            text-anchor="middle"
            letter-spacing="2"
          >{category.toUpperCase()}</text>
        </>
      );
    })()}
  </g>

  <!-- Title -->
  <text
    x={padX}
    y={titleY + 50}
    font-family={displayFont}
    font-size="60"
    font-weight="400"
    fill={brandColours.ink}
    letter-spacing="-1"
  >
    {titleLines.map((line, i) => (
      <tspan x={padX} dy={i === 0 ? 0 : 64}>{line}</tspan>
    ))}
  </text>

  <!-- One-liner -->
  <text
    x={padX}
    y={oneLinerY + 24}
    font-family={bodyFont}
    font-size="26"
    fill={brandColours.textMuted}
  >
    {oneLinerLines.map((line, i) => (
      <tspan x={padX} dy={i === 0 ? 0 : 36}>{line}</tspan>
    ))}
  </text>

  <!-- Divider -->
  <line
    x1={padX}
    y1={divider1Y}
    x2={W - padX}
    y2={divider1Y}
    stroke={brandColours.rule}
    stroke-width="1"
  />

  <!-- Thought-to-hold-onto block, in the category colour -->
  <rect
    x={padX}
    y={thoughtBoxY}
    width={W - padX * 2}
    height={thoughtBoxH}
    rx="8"
    ry="8"
    fill={accent}
  />
  <text
    x={padX + 36}
    y={thoughtLabelY}
    font-family={monoFont}
    font-size="14"
    font-weight="500"
    fill={onAccentText}
    letter-spacing="2"
    opacity="0.85"
  >A THOUGHT TO HOLD ONTO</text>
  <text
    x={padX + 36}
    y={thoughtTextY}
    font-family={displayFont}
    font-size="28"
    font-style="italic"
    fill={onAccentText}
  >
    {thoughtLines.map((line, i) => (
      <tspan x={padX + 36} dy={i === 0 ? 0 : 38}>{line}</tspan>
    ))}
  </text>

  <!-- Divider -->
  <line
    x1={padX}
    y1={divider2Y}
    x2={W - padX}
    y2={divider2Y}
    stroke={brandColours.rule}
    stroke-width="1"
  />

  <!-- Related concepts row -->
  {relatedItems.length > 0 && (
    <g>
      {relatedItems.map((item) => (
        <>
          <circle
            cx={item.x + dotR}
            cy={relatedY}
            r={dotR}
            fill={accent}
          />
          <text
            x={item.x + dotR * 2 + dotGap}
            y={relatedY + 7}
            font-family={bodyFont}
            font-size="20"
            font-weight="500"
            fill={brandColours.ink}
          >{item.title}</text>
        </>
      ))}
    </g>
  )}

  <!-- Footer -->
  <text
    x={W - padX}
    y={footerY}
    font-family={bodyFont}
    font-size="18"
    font-weight="500"
    fill={brandColours.textMuted}
    text-anchor="end"
  >moresapien.org</text>
</svg>

<style>
  .knowledge-card-svg {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
