---
// StayCurious.astro - Newsletter signup + Bluesky follow
// Restyled to the new Moresapien design tokens. Buttondown form action unchanged.
---

<div class="stay-curious">
  <p class="sc-heading">Stay curious</p>
  <p class="sc-subtext">Get new ideas in your inbox each month. No spam, ever.</p>

  <form
    action="https://buttondown.com/api/emails/embed-subscribe/moresapien"
    method="post"
    class="sc-form"
  >
    <div class="sc-input-row">
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        aria-label="Email address"
        class="sc-email"
      />
      <button type="submit" class="sc-submit">Subscribe</button>
    </div>
  </form>

  <div class="sc-divider"></div>

  <a
    href="https://bsky.app/profile/moresapien.bsky.social"
    target="_blank"
    rel="noopener noreferrer"
    class="sc-bluesky"
  >
    <svg width="16" height="16" viewBox="0 0 600 530" fill="currentColor" aria-hidden="true">
      <path d="M135.72 44.03C198.29 104.14 266.49 169.42 282.2 186.6c15.71-17.18 83.91-82.46 146.48-142.57C486.74-12.4 556.25-14.48 589.36 18.63c33.11 33.11 31.03 102.62-25.4 160.68-59.98 61.65-163.91 155.94-281.77 303.08C164.34 335.25 60.41 240.96.43 179.31-55.99 121.25-58.07 51.74-24.96 18.63 8.15-14.48 77.66-12.4 135.72 44.03z"/>
    </svg>
    <span>Follow on Bluesky</span>
  </a>
</div>

<style>
  .stay-curious {
    background: var(--ms-white);
    border: var(--ms-rule-width) solid var(--ms-rule);
    border-radius: var(--ms-radius-sm);
    padding: var(--ms-r5);
    font-family: var(--ms-font-ui);
  }

  .sc-heading {
    font-family: var(--ms-font-ui);
    font-size: 14px;
    font-weight: 500;
    color: var(--ms-ink);
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }

  .sc-subtext {
    font-family: var(--ms-font-body);
    font-size: 12px;
    color: var(--ms-mute);
    margin-bottom: var(--ms-r3);
    line-height: 1.5;
  }

  .sc-form {
    margin: 0;
  }

  .sc-input-row {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
  }

  .sc-email {
    width: 100%;
    height: 36px;
    padding: 0 12px;
    border: 1px solid var(--ms-rule);
    border-radius: var(--ms-radius-sm);
    background: var(--ms-paper);
    font-family: var(--ms-font-body);
    font-size: 13px;
    color: var(--ms-ink);
    outline: none;
    transition: border-color 0.15s ease;
  }

  .sc-email::placeholder {
    color: var(--ms-mute);
    opacity: 0.6;
  }

  .sc-email:focus {
    border-color: var(--ms-coral);
  }

  .sc-submit {
    height: 36px;
    padding: 0 16px;
    background: var(--ms-coral);
    color: var(--ms-white);
    border: none;
    border-radius: var(--ms-radius-sm);
    font-family: var(--ms-font-ui);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .sc-submit:hover {
    opacity: 0.88;
  }

  .sc-divider {
    height: 1px;
    background: var(--ms-rule);
    margin: var(--ms-r4) 0;
  }

  .sc-bluesky {
    display: flex;
    align-items: center;
    gap: var(--ms-r2);
    text-decoration: none;
    color: var(--ms-ink);
    font-family: var(--ms-font-ui);
    font-size: 13px;
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .sc-bluesky:hover {
    color: var(--ms-coral);
  }

  .sc-bluesky svg {
    flex-shrink: 0;
  }
</style>
