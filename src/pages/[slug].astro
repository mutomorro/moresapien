---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Asterisk from '../components/Asterisk.astro';
import ShareButton from '../components/ShareButton.jsx';
import StayCurious from '../components/StayCurious.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';
import ConnectionMiniMap from '../components/ConnectionMiniMap.astro';
import TableOfContents from '../components/TableOfContents.jsx';
import TableOfContentsMobile from '../components/TableOfContentsMobile.jsx';
import { getCategoryColor, getCategoryColorHex, getCategoryTextColor, getCategorySlug } from '../utils/categoryColors';
import { hasDiagram, loadDiagram } from '../data/diagramRegistry.js';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const {
  title,
  oneLiner,
  alsoKnownAs,
  category,
  tags,
  howToSpotIt,
  thoughtToHoldOnto,
  whyItMattersNow,
  relatedConcepts,
  furtherReading,
} = entry.data;

const { Content, headings: rawHeadings } = await render(entry);

// Filter to H2s only for the ToC
const tocHeadings = rawHeadings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, text: h.text }));

// Fixed sections that appear on every entry (with stable IDs for jump links)
const fixedSections = [
  { slug: 'how-to-spot-it', text: 'How to spot it' },
  { slug: 'thought-to-hold-onto', text: 'A thought to hold onto' },
];
if (whyItMattersNow) {
  fixedSections.push({ slug: 'why-it-matters-now', text: 'Why it matters now' });
}

const allEntries = await getCollection('entries');
const resolvedRelated = relatedConcepts.map((rel: { slug: string; note?: string }) => {
  const found = allEntries.find((e) => e.id === rel.slug);
  return {
    slug: rel.slug,
    title: found ? found.data.title : rel.slug,
    oneLiner: found ? found.data.oneLiner : '',
    category: found ? found.data.category : '',
    note: rel.note,
  };
});

const siteUrl = 'https://moresapien.org';
const pageUrl = siteUrl + '/' + entry.id + '/';

const accent = getCategoryColor(category);
const accentHex = getCategoryColorHex(category);
const onAccentText = getCategoryTextColor(category);

function renderInlineMarkdown(text: string): string {
  return (text || '').replace(/\*(.*?)\*/g, '<em>$1</em>');
}

const pageTitle = title + ' — Moresapien';
const pageDescription = title + ': ' + oneLiner + ' Learn about this ' + category.toLowerCase() + ' and how it affects your thinking.';
const ogImage = siteUrl + '/og/' + entry.id + '.png';
const thoughtHtml = renderInlineMarkdown(thoughtToHoldOnto);

const ogImageCaption = title + ' - ' + category + ' - Moresapien knowledge card';

const entryHasDiagram = hasDiagram(entry.id);
const DiagramComponent = entryHasDiagram ? await loadDiagram(entry.id) : null;
const diagramPngUrl = entryHasDiagram ? siteUrl + '/diagrams/' + entry.id + '.png' : null;
const diagramAltText = entryHasDiagram
  ? title + ' — ' + category + '. ' + oneLiner
  : null;

const baseImage = {
  '@type': 'ImageObject',
  url: ogImage,
  width: 1200,
  height: 630,
  caption: ogImageCaption,
};

const diagramImage = entryHasDiagram
  ? {
      '@type': 'ImageObject',
      url: diagramPngUrl,
      width: 1200,
      caption: 'How the ' + title.toLowerCase() + ' works — Moresapien concept diagram',
    }
  : null;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: title,
  description: oneLiner,
  url: pageUrl,
  image: diagramImage ? [baseImage, diagramImage] : baseImage,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Moresapien Knowledge Base',
    url: siteUrl + '/',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Moresapien',
    url: siteUrl + '/',
  },
};

const htmlStyle = `--page-accent: ${accent}; --page-accent-hex: ${accentHex}; --on-accent: ${onAccentText};`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={pageUrl}
  ogType="article"
  ogImage={ogImage}
  htmlStyle={htmlStyle}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <Nav />

  <main id="main" class="entry-page">
    <div class="entry-layout">
      <article class="entry">
        <header class="entry-header">
          <p class="eyebrow"><a href={`/browse/${getCategorySlug(category)}/`} class="eyebrow-link">{category}</a></p>
          <h1 class="entry-title">
            {title}<span class="title-asterisk">{' '}<Asterisk size={36} color="var(--page-accent)" /></span>
          </h1>
          <p class="entry-oneliner">{oneLiner}</p>

          {alsoKnownAs && alsoKnownAs.length > 0 && (
            <p class="also-known-as">
              <span class="aka-label">Also known as</span>
              <span class="aka-values">{alsoKnownAs.join(' · ')}</span>
            </p>
          )}
        </header>

        <!-- Mobile ToC: visible only below 960px -->
        {tocHeadings.length > 0 && (
          <div class="toc-mobile-wrapper">
            <TableOfContentsMobile
              client:load
              headings={tocHeadings}
              fixedSections={fixedSections}
              accentColor={accent}
            />
          </div>
        )}

        {entryHasDiagram && DiagramComponent ? (
          <div class="entry-visual entry-visual--diagram">
            <DiagramComponent category={category} />
            <img
              src={`/diagrams/${entry.id}.png`}
              alt={diagramAltText}
              title={`How ${title} works — Moresapien`}
              width="1200"
              height="auto"
              loading="lazy"
              class="diagram-png-fallback"
            />
          </div>
        ) : (
          <div class="entry-visual">
            <KnowledgeCard
              title={title}
              oneLiner={oneLiner}
              category={category}
              thoughtToHoldOnto={thoughtToHoldOnto}
              relatedConcepts={resolvedRelated}
              slug={entry.id}
            />
          </div>
        )}

        <div class="entry-body">
          <Content />
        </div>

        <section class="block block-spot" id="how-to-spot-it">
          <h2 class="block-label">How to spot it</h2>
          <p class="block-body" set:html={renderInlineMarkdown(howToSpotIt)} />
        </section>

        <section class="block block-thought" id="thought-to-hold-onto" aria-label="A thought to hold onto">
          <p class="block-thought-label">A thought to hold onto</p>
          <blockquote class="block-thought-text" set:html={thoughtHtml} />
        </section>

        {whyItMattersNow && (
          <section class="block block-matters" id="why-it-matters-now">
            <h2>Why it matters now</h2>
            <p set:html={renderInlineMarkdown(whyItMattersNow)} />
          </section>
        )}

        {furtherReading && furtherReading.length > 0 && (
          <section class="further-reading" aria-label="Further reading">
            <h2 class="further-reading-label">Further reading</h2>
            <ul class="further-reading-list">
              {furtherReading.map((item: { title: string; url: string }) => (
                <li>
                  <a href={item.url} target="_blank" rel="noopener noreferrer">
                    {item.title}<span class="further-reading-icon" aria-hidden="true">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <footer class="entry-footer">
          <div class="share-row">
            <span class="share-label">Found this useful?</span>
            <ShareButton
              client:load
              title={title}
              oneLiner={oneLiner}
              url={pageUrl}
              category={category}
            />
          </div>

          {resolvedRelated.length > 0 && (
            <div class="connection-map">
              <h3>How this connects</h3>
              <p class="map-hint">
                {title} sits alongside {resolvedRelated.length === 1 ? 'one related idea' : `${resolvedRelated.length} related ideas`} — a quick map of the neighbourhood.
              </p>
              <ConnectionMiniMap
                title={title}
                category={category}
                relatedConcepts={resolvedRelated}
                slug={entry.id}
              />
            </div>
          )}

          {resolvedRelated.length > 0 && (
            <div class="related-concepts">
              <h3>Related concepts</h3>
              <div class="related-grid">
                {resolvedRelated.map((related) => (
                  <a
                    href={`/${related.slug}/`}
                    class="related-card"
                    style={`--related-accent: ${getCategoryColor(related.category)};`}
                  >
                    <span class="related-eyebrow">{related.category}</span>
                    <span class="related-title">
                      {related.title}<span class="related-asterisk">{' '}<Asterisk size={11} color="var(--related-accent)" /></span>
                    </span>
                    <span class="related-oneliner">{related.oneLiner}</span>
                    {related.note && <span class="related-note">{related.note}</span>}
                  </a>
                ))}
              </div>
            </div>
          )}

          {tags && tags.length > 0 && (
            <div class="tag-row" aria-label="Tags">
              {tags.map((tag: string) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          )}
        </footer>
      </article>

      <div class="sc-mobile">
        <StayCurious />
      </div>

      <aside class="entry-sidebar" aria-label="Page navigation and newsletter">
        <div class="sidebar-sticky">
          {tocHeadings.length > 0 && (
            <TableOfContents
              client:load
              headings={tocHeadings}
              fixedSections={fixedSections}
              accentColor={accent}
            />
          )}
          <StayCurious />
        </div>
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .entry-page {
    padding: var(--ms-r7) var(--ms-r5) var(--ms-r9);
  }

  .entry-layout {
    max-width: 64rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 16rem;
    gap: var(--ms-r7);
    align-items: start;
  }

  .entry {
    min-width: 0;
    max-width: 38rem;
  }

  .entry-sidebar {
    position: sticky;
    top: 5rem;
  }

  .sidebar-sticky {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r5);
  }

  .sc-mobile {
    display: none;
  }

  /* --- Mobile ToC wrapper --- */
  .toc-mobile-wrapper {
    display: none;
    margin-bottom: var(--ms-r5);
  }

  /* --- Header --- */
  .entry-header {
    margin-bottom: var(--ms-r7);
  }

  .eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--page-accent);
    margin-bottom: var(--ms-r4);
  }

  .eyebrow-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  .eyebrow-link:hover {
    border-bottom-color: currentColor;
  }

  .entry-title {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h1);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }
  .title-asterisk {
    display: inline-block;
    white-space: nowrap;
    transform: translateY(-0.55em);
  }

  .entry-oneliner {
    font-family: var(--ms-font-body);
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--ms-mute);
    max-width: 38rem;
  }

  .also-known-as {
    margin-top: var(--ms-r4);
    display: flex;
    gap: var(--ms-r3);
    flex-wrap: wrap;
    align-items: baseline;
  }

  .aka-label {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
  }

  .aka-values {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    color: var(--ms-mute);
    font-style: italic;
  }

  /* --- Visual (knowledge card / diagram) --- */
  .entry-visual {
    margin-bottom: var(--ms-r7);
    border: 1px solid var(--ms-rule);
    border-radius: var(--ms-radius-md);
    overflow: hidden;
    background: var(--ms-white);
  }

  .entry-visual--diagram {
    padding: var(--ms-r5);
    position: relative;
  }

  .diagram-png-fallback {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
    padding: 0;
    margin: -1px;
  }

  .entry-visual :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  /* --- Body --- */
  .entry-body {
    margin-bottom: var(--ms-r7);
  }

  .entry-body :global(h2) {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h2);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--ms-ink);
    margin: var(--ms-r6) 0 var(--ms-r4);
    scroll-margin-top: 5.5rem;
  }

  .entry-body :global(h2:first-child) {
    margin-top: 0;
  }

  .entry-body :global(h3) {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h3);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
    margin: var(--ms-r6) 0 var(--ms-r3);
    scroll-margin-top: 5.5rem;
  }

  .entry-body :global(p) {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .entry-body :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  .entry-body :global(a) {
    color: var(--ms-ink);
    border-bottom: 1px solid var(--page-accent);
    transition: color 0.15s ease;
  }

  .entry-body :global(a:hover) {
    color: var(--page-accent);
  }

  /* --- Block: How to spot it --- */
  .block {
    margin-bottom: var(--ms-r7);
    scroll-margin-top: 5.5rem;
  }

  .block-spot {
    background: var(--ms-white);
    border-left: var(--ms-accent-rule-width) solid var(--page-accent);
    border-top: 1px solid var(--ms-rule);
    border-right: 1px solid var(--ms-rule);
    border-bottom: 1px solid var(--ms-rule);
    border-radius: 0 var(--ms-radius-sm) var(--ms-radius-sm) 0;
    padding: var(--ms-r5) var(--ms-r6);
  }

  .block-spot .block-label {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--page-accent);
    margin-bottom: var(--ms-r3);
  }

  .block-spot .block-body {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
  }

  .block-spot :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  /* --- Block: Thought to hold onto --- */
  .block-thought {
    background: var(--page-accent);
    border-radius: var(--ms-radius-md);
    padding: var(--ms-r6);
    color: var(--on-accent);
  }

  .block-thought-label {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--on-accent);
    opacity: 0.85;
    margin-bottom: var(--ms-r4);
  }

  .block-thought-text {
    font-family: var(--ms-font-display);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.45;
    color: var(--on-accent);
  }

  .block-thought-text :global(em) {
    font-style: italic;
    color: inherit;
    opacity: 0.85;
  }

  /* --- Block: Why it matters now --- */
  .block-matters {
    border-top: 1px solid var(--ms-rule);
    padding-top: var(--ms-r6);
  }

  .block-matters h2 {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h2);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r3);
  }

  .block-matters p {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
  }

  .block-matters :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  /* --- Further reading --- */
  .further-reading {
    margin-bottom: var(--ms-r7);
    padding-top: var(--ms-r5);
    border-top: 1px solid var(--ms-rule);
  }

  .further-reading-label {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
    margin-bottom: var(--ms-r3);
  }

  .further-reading-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
  }

  .further-reading-list a {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    color: var(--ms-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ms-rule);
    padding-bottom: 2px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .further-reading-list a:hover {
    color: var(--page-accent);
    border-bottom-color: var(--page-accent);
  }

  .further-reading-icon {
    display: inline-block;
    margin-left: 0.3em;
    font-size: 0.85em;
    color: var(--ms-mute);
  }

  /* --- Footer of entry --- */
  .entry-footer {
    margin-top: var(--ms-r8);
    padding-top: var(--ms-r6);
    border-top: 1px solid var(--ms-rule);
  }

  .share-row {
    display: flex;
    align-items: center;
    gap: var(--ms-r4);
    margin-bottom: var(--ms-r7);
  }

  .share-label {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    color: var(--ms-mute);
  }

  .connection-map {
    margin-bottom: var(--ms-r7);
  }

  .connection-map h3,
  .related-concepts h3 {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h3);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r3);
  }

  .map-hint {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    color: var(--ms-mute);
    font-style: italic;
    margin-bottom: var(--ms-r4);
  }

  .connection-map :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  /* --- Related concepts --- */
  .related-concepts {
    margin-bottom: var(--ms-r6);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--ms-r4);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    padding: var(--ms-r4);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-top: var(--ms-accent-rule-width) solid var(--related-accent);
    border-radius: var(--ms-radius-sm);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .related-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .related-eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--related-accent);
  }

  .related-title {
    font-family: var(--ms-font-display);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
  }
  .related-asterisk {
    display: inline-block;
    white-space: nowrap;
    transform: translateY(-0.55em);
  }

  .related-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    color: var(--ms-mute);
    line-height: 1.5;
  }

  .related-note {
    font-family: var(--ms-font-body);
    font-size: 12px;
    color: var(--ms-mute);
    font-style: italic;
    line-height: 1.5;
    margin-top: var(--ms-r2);
    padding-top: var(--ms-r2);
    border-top: 1px solid var(--ms-rule);
  }

  /* --- Tags --- */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ms-r2);
    padding-top: var(--ms-r4);
    border-top: 1px solid var(--ms-rule);
  }

  .tag {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    color: var(--ms-mute);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  /* =============================================
     Table of Contents — Desktop (sidebar)
     ============================================= */
  .entry-sidebar :global(.toc) {
    padding: 0;
  }

  .entry-sidebar :global(.toc-label) {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
    margin: 0 0 var(--ms-r3);
  }

  .entry-sidebar :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .entry-sidebar :global(.toc-item) {
    border-left: 2px solid transparent;
    padding: 0.3rem 0 0.3rem 0.75rem;
    transition: border-color 0.2s ease;
  }

  .entry-sidebar :global(.toc-item--active) {
    border-left-width: 2px;
    border-left-style: solid;
  }

  .entry-sidebar :global(.toc-link) {
    font-family: var(--ms-font-body);
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--ms-mute);
    text-decoration: none;
