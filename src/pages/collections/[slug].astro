---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Asterisk from '../../components/Asterisk.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import { getCategoryColor } from '../../utils/categoryColors';

export async function getStaticPaths() {
  const collections = await getCollection('curatedCollections');
  return collections.map((collection) => ({
    params: { slug: collection.id },
    props: { collection },
  }));
}

const { collection } = Astro.props;
const { title, type, audience, collectionEntries } = collection.data;

function splitLastWord(s: string) {
  const i = s.lastIndexOf(' ');
  return {
    head: i === -1 ? '' : s.slice(0, i + 1),
    tail: i === -1 ? s : s.slice(i + 1),
  };
}

const titleSplit = splitLastWord(title);

const allEntries = await getCollection('entries');
const resolvedEntries = collectionEntries.map((slug: string, index: number) => {
  const found = allEntries.find((e) => e.id === slug);
  const entryTitle = found ? found.data.title : slug;
  const split = splitLastWord(entryTitle);
  return {
    slug,
    title: entryTitle,
    titleHead: split.head,
    titleTail: split.tail,
    oneLiner: found ? found.data.oneLiner : '',
    category: found ? found.data.category : '',
    index: index + 1,
  };
});

// Split the markdown body into intro + stages (at H2 headings)
const rawBody = collection.body || '';
const sections = rawBody.split(/(?=^## )/m);
const introMd = sections[0]?.trim() || '';
const stageSections = sections.slice(1);

// Interleaved format = the markdown body has H2 stage sections.
// Classic format = single intro + list of entries.
const isInterleaved = stageSections.length > 0;

// Narrative part dividers - keyed by stage index (0-based).
const partDividers: Record<number, string> = {
  5: 'How the crowd pulls you in',
  8: 'The deliberate tactics',
  14: 'What happens when it works',
};

const stages = stageSections.map((section: string, i: number) => {
  const lines = section.split('\n');
  const headingLine = lines[0] || '';
  const heading = headingLine.replace(/^## /, '').trim();
  const body = lines.slice(1).join('\n').trim();
  return {
    heading,
    bodyHtml: marked.parse(body),
    entry: resolvedEntries[i] || null,
    number: i + 1,
    dividerLabel: partDividers[i] || null,
  };
});

const { Content } = await render(collection);
const introHtml = introMd ? marked.parse(introMd) : '';

const siteUrl = 'https://moresapien.org';
const pageUrl = siteUrl + '/collections/' + collection.id + '/';
const pageTitle = title + ' - Moresapien';

// Meta descriptions truncated to ~155 chars to fit Google's display limit.
function trimForMeta(s: string, max = 155): string {
  if (s.length <= max) return s;
  const cut = s.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 100 ? cut.slice(0, lastSpace) : cut).replace(/[.,;:\s]+$/, '') + '…';
}
const pageDescription = trimForMeta(audience);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: pageUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Moresapien',
    url: siteUrl + '/',
  },
  mainEntity: resolvedEntries.map((e: { slug: string; title: string }) => ({
    '@type': 'DefinedTerm',
    name: e.title,
    url: siteUrl + '/' + e.slug + '/',
  })),
};
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={pageUrl}
  ogType="article"
>
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  <BreadcrumbSchema items={[
    { name: 'Home', url: siteUrl + '/' },
    { name: 'Collections', url: siteUrl + '/collections/' },
    { name: title },
  ]} />

  <Nav currentPage="collections" />

  <main id="main" class="collection-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/collections/">← All collections</a>
    </nav>

    <article class="collection">
      <header class="collection-header">
        <p class="eyebrow">Collection</p>
        <h1 class="collection-title">
          {titleSplit.head}<span class="title-tail">{titleSplit.tail}{' '}<span class="title-asterisk"><Asterisk size={28} /></span></span>
        </h1>
        <p class="collection-audience">{audience}</p>
      </header>

      {isInterleaved ? (
        <>
          <div class="collection-intro" set:html={introHtml} />

          <div class="stages">
            {stages.map((stage) => {
              const accent = stage.entry ? getCategoryColor(stage.entry.category) : 'var(--ms-mute)';
              return (
                <>
                  {stage.dividerLabel && (
                    <div class="part-divider">
                      <span class="part-divider-line"></span>
                      <span class="part-divider-label">{stage.dividerLabel}</span>
                      <span class="part-divider-line"></span>
                    </div>
                  )}

                  <section class="stage" style={`--entry-accent: ${accent};`}>
                    <span class="stage-number" aria-hidden="true">{String(stage.number).padStart(2, '0')}</span>

                    <div class="stage-content">
                      <h2 class="stage-heading">{stage.heading}</h2>
                      <div class="stage-body" set:html={stage.bodyHtml} />
                    </div>

                    {stage.entry && (
                      <a href={`/${stage.entry.slug}/`} class="stage-aside">
                        <span class="aside-eyebrow">Concept</span>
                        <span class="aside-category">{stage.entry.category}</span>
                        <span class="aside-title">
                          {stage.entry.titleHead}<span class="entry-tail">{stage.entry.titleTail}{' '}<span class="entry-asterisk"><Asterisk size={11} color="var(--entry-accent)" /></span></span>
                        </span>
                        <span class="aside-oneliner">{stage.entry.oneLiner}</span>
                        <span class="aside-cta">Read →</span>
                      </a>
                    )}
                  </section>
                </>
              );
            })}
          </div>
        </>
      ) : (
        <>
          <div class="collection-intro">
            <Content />
          </div>

          <section class="collection-entries">
            <h2 class="section-heading">{type === 'pathway' ? 'The journey' : 'In this toolkit'}</h2>

            {type === 'pathway' ? (
              <ol class="pathway-list">
                {resolvedEntries.map((entry) => (
                  <li>
                    <a
                      href={`/${entry.slug}/`}
                      class="pathway-item"
                      style={`--entry-accent: ${getCategoryColor(entry.category)};`}
                    >
                      <span class="pathway-number">{String(entry.index).padStart(2, '0')}</span>
                      <div class="pathway-content">
                        <span class="pathway-category">{entry.category}</span>
                        <span class="pathway-title">
                          {entry.titleHead}<span class="entry-tail">{entry.titleTail}{' '}<span class="entry-asterisk"><Asterisk size={11} color="var(--entry-accent)" /></span></span>
                        </span>
                        <span class="pathway-oneliner">{entry.oneLiner}</span>
                      </div>
                    </a>
                  </li>
                ))}
              </ol>
            ) : (
              <div class="toolkit-grid">
                {resolvedEntries.map((entry) => (
                  <a
                    href={`/${entry.slug}/`}
                    class="toolkit-card"
                    style={`--entry-accent: ${getCategoryColor(entry.category)};`}
                  >
                    <span class="toolkit-category">{entry.category}</span>
                    <span class="toolkit-title">
                      {entry.titleHead}<span class="entry-tail">{entry.titleTail}{' '}<span class="entry-asterisk"><Asterisk size={11} color="var(--entry-accent)" /></span></span>
                    </span>
                    <span class="toolkit-oneliner">{entry.oneLiner}</span>
                  </a>
                ))}
              </div>
            )}
          </section>
        </>
      )}
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .collection-page {
    max-width: 60rem;
    margin: 0 auto;
    padding: var(--ms-r6) var(--ms-r5) var(--ms-r9);
  }

  .breadcrumb {
    margin-bottom: var(--ms-r6);
  }

  .breadcrumb a {
    font-family: var(--ms-font-ui);
    font-size: 13px;
    color: var(--ms-mute);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--ms-coral);
  }

  .eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-coral);
    margin-bottom: var(--ms-r3);
  }

  .collection-header {
    margin-bottom: var(--ms-r7);
    padding-bottom: var(--ms-r6);
    border-bottom: 1px solid var(--ms-rule);
  }

  .collection-title {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h1);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .title-tail,
  .entry-tail {
    white-space: nowrap;
  }
  .title-asterisk,
  .entry-asterisk {
    display: inline-block;
    transform: translateY(-0.55em);
  }

  .collection-audience {
    font-family: var(--ms-font-body);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--ms-mute);
  }

  .collection-intro {
    margin-bottom: var(--ms-r8);
    max-width: 38rem;
  }

  .collection-intro :global(p) {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .collection-intro :global(p:last-child) {
    margin-bottom: 0;
  }

  .collection-intro :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  /* --- Interleaved stages --- */
  .stages {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r8);
  }

  .stage {
    display: grid;
    grid-template-columns: minmax(0, 38rem) minmax(0, 13rem);
    grid-template-areas:
      "number  ."
      "content aside";
    column-gap: var(--ms-r6);
    row-gap: var(--ms-r4);
  }

  .stage-number {
    grid-area: number;
    font-family: var(--ms-font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(4.5rem, 8vw, 6.5rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: var(--entry-accent);
  }

  .stage-content {
    grid-area: content;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r4);
  }

  .stage-heading {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h3);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ms-ink);
    margin: 0;
  }

  .stage-body :global(p) {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .stage-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .stage-body :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  /* Concept aside - sits beside the body, links to the entry */
  .stage-aside {
    grid-area: aside;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    padding-left: var(--ms-r4);
    border-left: 2px solid var(--entry-accent);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .stage-aside:hover {
    transform: translateX(2px);
  }

  .stage-aside:hover .aside-title {
    color: var(--entry-accent);
  }

  .aside-eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
  }

  .aside-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
    margin-top: var(--ms-r2);
  }

  .aside-title {
    font-family: var(--ms-font-display);
    font-size: 1.0625rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--ms-ink);
    transition: color 0.15s ease;
  }

  .aside-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.5;
    color: var(--ms-mute);
    margin-top: var(--ms-r2);
  }

  .aside-cta {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
    margin-top: var(--ms-r3);
  }

  /* Part dividers */
  .part-divider {
    display: flex;
    align-items: center;
    gap: var(--ms-r4);
    margin: var(--ms-r5) 0 var(--ms-r3);
  }

  .part-divider-line {
    flex: 1;
    height: 1px;
    background: var(--ms-rule);
  }

  .part-divider-label {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
    white-space: nowrap;
  }

  /* --- Classic format (intro + list) --- */
  .section-heading {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h2);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r5);
  }

  .pathway-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r3);
  }

  .pathway-item {
    display: flex;
    align-items: flex-start;
    gap: var(--ms-r5);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-left: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: 0 var(--ms-radius-sm) var(--ms-radius-sm) 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pathway-item:hover {
    transform: translateX(2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .pathway-number {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    color: var(--entry-accent);
    letter-spacing: 0.1em;
    margin-top: 4px;
    flex-shrink: 0;
    min-width: 24px;
  }

  .pathway-content {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    min-width: 0;
  }

  .pathway-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .pathway-title {
    font-family: var(--ms-font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
  }

  .pathway-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  .toolkit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--ms-r4);
  }

  .toolkit-card {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-top: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: var(--ms-radius-sm);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .toolkit-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .toolkit-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .toolkit-title {
    font-family: var(--ms-font-display);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
  }

  .toolkit-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  /* Tablet: keep the two-column layout but tighten the gap */
  @media (max-width: 880px) {
    .stage {
      grid-template-columns: minmax(0, 1fr) minmax(0, 11rem);
      column-gap: var(--ms-r5);
    }
  }

  /* Mobile: collapse to single column, aside becomes a quiet footer block */
  @media (max-width: 720px) {
    .collection-page {
      padding: var(--ms-r5) var(--ms-r4) var(--ms-r8);
    }
    .stages {
      gap: var(--ms-r7);
    }
    .stage {
      grid-template-columns: 1fr;
      grid-template-areas:
        "number"
        "content"
        "aside";
      row-gap: var(--ms-r3);
    }
    .stage-number {
      font-size: 4rem;
    }
    .stage-aside {
      margin-top: var(--ms-r3);
    }
    .pathway-item {
      padding: var(--ms-r4);
      gap: var(--ms-r3);
    }
    .toolkit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
