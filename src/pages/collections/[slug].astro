---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Asterisk from '../../components/Asterisk.astro';
import { getCategoryColor } from '../../utils/categoryColors';

export async function getStaticPaths() {
  const collections = await getCollection('curatedCollections');
  return collections.map((collection) => ({
    params: { slug: collection.id },
    props: { collection },
  }));
}

const { collection } = Astro.props;
const { title, type, audience, collectionEntries } = collection.data;

const allEntries = await getCollection('entries');
const resolvedEntries = collectionEntries.map((slug: string, index: number) => {
  const found = allEntries.find((e) => e.id === slug);
  return {
    slug,
    title: found ? found.data.title : slug,
    oneLiner: found ? found.data.oneLiner : '',
    category: found ? found.data.category : '',
    index: index + 1,
  };
});

// Split the markdown body into intro + stages (at H2 headings)
const rawBody = collection.body || '';
const sections = rawBody.split(/(?=^## )/m);
const introMd = sections[0]?.trim() || '';
const stageSections = sections.slice(1);

// Interleaved format = the markdown body has H2 stage sections.
// Classic format = single intro + list of entries.
const isInterleaved = stageSections.length > 0;

// Narrative part dividers — keyed by stage index (0-based).
const partDividers: Record<number, string> = {
  5: 'How the crowd pulls you in',
  8: 'The deliberate tactics',
  14: 'What happens when it works',
};

const stages = stageSections.map((section: string, i: number) => {
  const lines = section.split('\n');
  const headingLine = lines[0] || '';
  const heading = headingLine.replace(/^## /, '').trim();
  const body = lines.slice(1).join('\n').trim();
  return {
    heading,
    bodyHtml: marked.parse(body),
    entry: resolvedEntries[i] || null,
    number: i + 1,
    dividerLabel: partDividers[i] || null,
  };
});

const { Content } = await render(collection);
const introHtml = introMd ? marked.parse(introMd) : '';

const siteUrl = 'https://moresapien.org';
const pageUrl = siteUrl + '/collections/' + collection.id + '/';
const pageTitle = title + ' — Moresapien';
---
<BaseLayout
  title={pageTitle}
  description={audience}
  canonical={pageUrl}
  ogType="article"
>
  <Nav currentPage="collections" />

  <main id="main" class="collection-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/collections/">← All collections</a>
    </nav>

    <article class="collection">
      <header class="collection-header">
        <p class="eyebrow">{type === 'pathway' ? 'Learning pathway' : 'Toolkit'}</p>
        <h1 class="collection-title">
          {title}<span class="title-asterisk">{' '}<Asterisk size={28} /></span>
        </h1>
        <p class="collection-audience">{audience}</p>
      </header>

      {isInterleaved ? (
        <>
          <div class="collection-intro" set:html={introHtml} />

          <div class="stages">
            {stages.map((stage) => {
              const accent = stage.entry ? getCategoryColor(stage.entry.category) : 'var(--ms-mute)';
              return (
                <>
                  {stage.dividerLabel && (
                    <div class="part-divider">
                      <span class="part-divider-line"></span>
                      <span class="part-divider-label">{stage.dividerLabel}</span>
                      <span class="part-divider-line"></span>
                    </div>
                  )}

                  <section class="stage" style={`--entry-accent: ${accent};`}>
                    <header class="stage-header">
                      <span class="stage-number">{String(stage.number).padStart(2, '0')}</span>
                      <h2 class="stage-heading">{stage.heading}</h2>
                    </header>

                    <div class="stage-body" set:html={stage.bodyHtml} />

                    {stage.entry && (
                      <a href={`/${stage.entry.slug}/`} class="entry-card">
                        <span class="entry-category">{stage.entry.category}</span>
                        <span class="entry-title">
                          {stage.entry.title}<span class="entry-asterisk">{' '}<Asterisk size={11} color="var(--entry-accent)" /></span>
                        </span>
                        <span class="entry-oneliner">{stage.entry.oneLiner}</span>
                      </a>
                    )}
                  </section>
                </>
              );
            })}
          </div>
        </>
      ) : (
        <>
          <div class="collection-intro">
            <Content />
          </div>

          <section class="collection-entries">
            <h2 class="section-heading">{type === 'pathway' ? 'The journey' : 'In this toolkit'}</h2>

            {type === 'pathway' ? (
              <ol class="pathway-list">
                {resolvedEntries.map((entry) => (
                  <li>
                    <a
                      href={`/${entry.slug}/`}
                      class="pathway-item"
                      style={`--entry-accent: ${getCategoryColor(entry.category)};`}
                    >
                      <span class="pathway-number">{String(entry.index).padStart(2, '0')}</span>
                      <div class="pathway-content">
                        <span class="pathway-category">{entry.category}</span>
                        <span class="pathway-title">
                          {entry.title}<span class="entry-asterisk">{' '}<Asterisk size={11} color="var(--entry-accent)" /></span>
                        </span>
                        <span class="pathway-oneliner">{entry.oneLiner}</span>
                      </div>
                    </a>
                  </li>
                ))}
              </ol>
            ) : (
              <div class="toolkit-grid">
                {resolvedEntries.map((entry) => (
                  <a
                    href={`/${entry.slug}/`}
                    class="toolkit-card"
                    style={`--entry-accent: ${getCategoryColor(entry.category)};`}
                  >
                    <span class="toolkit-category">{entry.category}</span>
                    <span class="toolkit-title">
                      {entry.title}<span class="entry-asterisk">{' '}<Asterisk size={11} color="var(--entry-accent)" /></span>
                    </span>
                    <span class="toolkit-oneliner">{entry.oneLiner}</span>
                  </a>
                ))}
              </div>
            )}
          </section>
        </>
      )}
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .collection-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--ms-r6) var(--ms-r5) var(--ms-r9);
  }

  .breadcrumb {
    margin-bottom: var(--ms-r6);
  }

  .breadcrumb a {
    font-family: var(--ms-font-ui);
    font-size: 13px;
    color: var(--ms-mute);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--ms-coral);
  }

  .eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-coral);
    margin-bottom: var(--ms-r3);
  }

  .collection-header {
    margin-bottom: var(--ms-r7);
    padding-bottom: var(--ms-r6);
    border-bottom: 1px solid var(--ms-rule);
  }

  .collection-title {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h1);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .title-asterisk,
  .entry-asterisk {
    display: inline-block;
    white-space: nowrap;
    transform: translateY(-0.55em);
  }

  .collection-audience {
    font-family: var(--ms-font-body);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--ms-mute);
  }

  .collection-intro {
    margin-bottom: var(--ms-r8);
    max-width: 38rem;
  }

  .collection-intro :global(p) {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .collection-intro :global(p:last-child) {
    margin-bottom: 0;
  }

  .collection-intro :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  /* --- Interleaved stages --- */
  .stages {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r7);
  }

  .stage {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r4);
  }

  .stage-header {
    display: flex;
    align-items: baseline;
    gap: var(--ms-r4);
  }

  .stage-number {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    letter-spacing: 0.1em;
    color: var(--entry-accent);
    flex-shrink: 0;
  }

  .stage-heading {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h3);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ms-ink);
    margin: 0;
  }

  .stage-body {
    max-width: 38rem;
  }

  .stage-body :global(p) {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .stage-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .stage-body :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  /* Entry card inside a stage */
  .entry-card {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-left: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: 0 var(--ms-radius-sm) var(--ms-radius-sm) 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .entry-card:hover {
    transform: translateX(2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .entry-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .entry-title {
    font-family: var(--ms-font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
  }

  .entry-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  /* Part dividers */
  .part-divider {
    display: flex;
    align-items: center;
    gap: var(--ms-r4);
    margin: var(--ms-r5) 0 var(--ms-r3);
  }

  .part-divider-line {
    flex: 1;
    height: 1px;
    background: var(--ms-rule);
  }

  .part-divider-label {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
    white-space: nowrap;
  }

  /* --- Classic format (intro + list) --- */
  .section-heading {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h2);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r5);
  }

  .pathway-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r3);
  }

  .pathway-item {
    display: flex;
    align-items: flex-start;
    gap: var(--ms-r5);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-left: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: 0 var(--ms-radius-sm) var(--ms-radius-sm) 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pathway-item:hover {
    transform: translateX(2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .pathway-number {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    color: var(--entry-accent);
    letter-spacing: 0.1em;
    margin-top: 4px;
    flex-shrink: 0;
    min-width: 24px;
  }

  .pathway-content {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    min-width: 0;
  }

  .pathway-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .pathway-title {
    font-family: var(--ms-font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
  }

  .pathway-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  .toolkit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--ms-r4);
  }

  .toolkit-card {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-top: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: var(--ms-radius-sm);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .toolkit-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .toolkit-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .toolkit-title {
    font-family: var(--ms-font-display);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
  }

  .toolkit-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  @media (max-width: 640px) {
    .collection-page {
      padding: var(--ms-r5) var(--ms-r4) var(--ms-r8);
    }
    .stages {
      gap: var(--ms-r6);
    }
    .pathway-item {
      padding: var(--ms-r4);
      gap: var(--ms-r3);
    }
    .toolkit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
