---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import Nav from '../../components/Nav.astro';

export async function getStaticPaths() {
  const collections = await getCollection('curatedCollections');
  return collections.map((collection) => ({
    params: { slug: collection.id },
    props: { collection },
  }));
}

const { collection } = Astro.props;
const { title, type, audience, collectionEntries, tags } = collection.data;

const allEntries = await getCollection('entries');
const resolvedEntries = collectionEntries.map((slug: string, index: number) => {
  const found = allEntries.find((e) => e.id === slug);
  return {
    slug,
    title: found ? found.data.title : slug,
    oneLiner: found ? found.data.oneLiner : '',
    category: found ? found.data.category : '',
    index: index + 1,
  };
});

const categoryColours = {
  'Cognitive Bias': '#D4A574',
  'Logical Fallacy': '#7EA886',
  'Mental Model': '#C4956A',
  'Political Theory': '#B07AA1',
  'Rhetorical Device': '#8B9FC5',
  'Systems Thinking': '#6BA3A0',
  'Manipulation Tactic': '#C47A7A',
  'Psychological Phenomenon': '#9B8EC4',
  'Psychological Defence': '#7AACB0',
  'Cultural Influence': '#8A7A5B',
};

// Split the markdown body into intro + stages (at H2 headings)
const rawBody = collection.body || '';
const sections = rawBody.split(/(?=^## )/m);
const introMd = sections[0]?.trim() || '';
const stageSections = sections.slice(1);

// Check if this collection uses the interleaved format (has H2 sections)
const isInterleaved = stageSections.length > 0;

// Part dividers - keyed by stage index (0-based)
// These insert narrative section breaks at specific points in the journey
const partDividers = {
  5: 'How the crowd pulls you in',
  8: 'The deliberate tactics',
  14: 'What happens when it works',
};

// Parse each stage: extract heading + body
const stages = stageSections.map((section: string, i: number) => {
  const lines = section.split('\n');
  const headingLine = lines[0] || '';
  const heading = headingLine.replace(/^## /, '').trim();
  const body = lines.slice(1).join('\n').trim();
  return {
    heading,
    bodyHtml: marked.parse(body),
    entry: resolvedEntries[i] || null,
    number: i + 1,
    dividerLabel: partDividers[i] || null,
  };
});

// For non-interleaved collections, render the full content
const { Content } = await render(collection);
const introHtml = introMd ? marked.parse(introMd) : '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Moresapien</title>
    <meta name="description" content={audience} />

    <meta property="og:title" content={`${title} - Moresapien`} />
    <meta property="og:description" content={audience} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://moresapien.org/collections/${collection.id}/`} />

    <link rel="canonical" href={`https://moresapien.org/collections/${collection.id}/`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400&family=General+Sans:wght@400;500;600&family=Space+Grotesk:wght@400;500;600&family=DM+Mono:wght@400&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'General Sans', -apple-system, sans-serif;
        background: #FFFBF5;
        color: #4a4540;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      .page-wrapper {
        max-width: 720px;
        margin: 0 auto;
        padding: 2.5rem 2rem 4rem;
      }

      .collection-type-badge {
        display: inline-block;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.2rem 0.6rem;
        border-radius: 0.3rem;
        margin-bottom: 1rem;
      }

      .badge-pathway {
        color: #C4622D;
        background: rgba(196, 98, 45, 0.08);
      }

      .badge-toolkit {
        color: #2E6B6B;
        background: rgba(46, 107, 107, 0.08);
      }

      .collection-title {
        font-family: 'Newsreader', serif;
        font-size: 2rem;
        font-weight: 600;
        color: #2c2825;
        line-height: 1.25;
        margin-bottom: 0.5rem;
      }

      .collection-audience {
        font-size: 1rem;
        line-height: 1.6;
        color: #8a7f72;
        margin-bottom: 2rem;
      }

      .header-rule {
        width: 100%;
        height: 1px;
        background: #e8e0d8;
        margin-bottom: 2rem;
      }

      .collection-intro {
        margin-bottom: 2.5rem;
      }

      .collection-intro :global(p) {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: #4a4540;
        margin-bottom: 0.75rem;
      }

      .collection-intro :global(p:last-child) {
        margin-bottom: 0;
      }

      .stage {
        margin-bottom: 2.5rem;
      }

      .stage-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }

      .stage-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 50%;
        background: #f5f0ea;
        color: #8a7f72;
        font-family: 'DM Mono', monospace;
        font-weight: 400;
        font-size: 0.75rem;
        flex-shrink: 0;
      }

      .stage-heading {
        font-family: 'Newsreader', serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: #2c2825;
        line-height: 1.3;
      }

      .stage-body {
        margin-bottom: 1.25rem;
      }

      .stage-body :global(p) {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: #4a4540;
        margin-bottom: 0.75rem;
      }

      .stage-body :global(p:last-child) {
        margin-bottom: 0;
      }

      .entry-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: #f9f5ef;
        border-radius: 0.75rem;
        text-decoration: none;
        transition: background 0.15s ease, transform 0.15s ease;
      }

      .entry-card:hover {
        background: #f3ede4;
        transform: translateY(-1px);
      }

      .entry-accent {
        flex-shrink: 0;
        width: 4px;
        height: 3rem;
        border-radius: 2px;
      }

      .entry-content {
        flex: 1;
        min-width: 0;
      }

      .entry-category {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.125rem;
      }

      .entry-title {
        font-family: 'Newsreader', serif;
        font-size: 1.0625rem;
        font-weight: 600;
        color: #2c2825;
        margin-bottom: 0.125rem;
      }

      .entry-oneliner {
        font-size: 0.875rem;
        color: #8a7f72;
        line-height: 1.5;
      }

      .entry-arrow {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 50%;
        border: 1px solid #e8e0d8;
        color: #8a7f72;
        transition: border-color 0.15s ease, color 0.15s ease;
      }

      .entry-card:hover .entry-arrow {
        border-color: #d0c8be;
        color: #6a6058;
      }

      .entry-arrow svg {
        width: 1rem;
        height: 1rem;
      }

      .part-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 3rem 0 2.5rem;
      }

      .part-divider-line {
        flex: 1;
        height: 1px;
        background: #e8e0d8;
      }

      .part-divider-label {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #b0a89e;
        white-space: nowrap;
      }

      /* Fallback: classic list layout for non-interleaved collections */
      .classic-intro {
        margin-bottom: 2.5rem;
      }

      .classic-intro :global(p) {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: #4a4540;
        margin-bottom: 0.75rem;
      }

      .entries-heading {
        font-family: 'Newsreader', serif;
        font-size: 1.375rem;
        font-weight: 600;
        color: #2c2825;
        margin-bottom: 1.5rem;
      }

      .pathway-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .pathway-item {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 0.75rem;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
      }

      .pathway-item:hover {
        border-color: #d0c8be;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transform: translateY(-1px);
      }

      .pathway-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 50%;
        background: #f5f0ea;
        color: #8a7f72;
        font-family: 'DM Mono', monospace;
        font-weight: 400;
        font-size: 0.875rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
      }

      .pathway-content {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .pathway-category {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .pathway-title {
        font-family: 'Newsreader', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c2825;
      }

      .pathway-oneliner {
        font-size: 0.875rem;
        color: #8a7f72;
        line-height: 1.5;
      }

      .toolkit-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
      }

      .toolkit-card {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1.25rem 1.5rem;
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 0.75rem;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
      }

      .toolkit-card:hover {
        border-color: #d0c8be;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transform: translateY(-1px);
      }

      .toolkit-category {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .toolkit-title {
        font-family: 'Newsreader', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c2825;
      }

      .toolkit-oneliner {
        font-size: 0.875rem;
        color: #8a7f72;
        line-height: 1.5;
      }

      .site-footer {
        text-align: center;
        padding-top: 3rem;
        border-top: 1px solid #e8e0d8;
        margin-top: 3rem;
        font-size: 0.875rem;
        color: #b0a89e;
      }

      .site-footer a {
        color: #8B5E3C;
        text-decoration: none;
      }

      .site-footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 600px) {
        .page-wrapper {
          padding: 1.5rem 1.25rem 3rem;
        }

        .collection-title {
          font-size: 1.625rem;
        }

        .stage-heading {
          font-size: 1.125rem;
        }

        .entry-card {
          padding: 0.875rem 1rem;
        }

        .entry-oneliner {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <Nav currentPage="collections" />
    <div class="page-wrapper">

      <span class:list={['collection-type-badge', type === 'pathway' ? 'badge-pathway' : 'badge-toolkit']}>
        {type === 'pathway' ? 'Learning pathway' : 'Toolkit'}
      </span>

      <h1 class="collection-title">{title}</h1>
      <p class="collection-audience">{audience}</p>

      <div class="header-rule"></div>

      {isInterleaved ? (
        <>
          <div class="collection-intro" set:html={introHtml} />

          {stages.map((stage) => {
            const colour = stage.entry ? (categoryColours[stage.entry.category] || '#8a7f72') : '#8a7f72';

            return (
              <>
                {stage.dividerLabel && (
                  <div class="part-divider">
                    <div class="part-divider-line"></div>
                    <span class="part-divider-label">{stage.dividerLabel}</span>
                    <div class="part-divider-line"></div>
                  </div>
                )}

                <div class="stage">
                  <div class="stage-header">
                    <span class="stage-number">{stage.number}</span>
                    <h2 class="stage-heading">{stage.heading}</h2>
                  </div>

                  <div class="stage-body" set:html={stage.bodyHtml} />

                  {stage.entry && (
                    <a href={`/${stage.entry.slug}/`} class="entry-card">
                      <div class="entry-accent" style={`background: ${colour};`}></div>
                      <div class="entry-content">
                        <div class="entry-category" style={`color: ${colour};`}>{stage.entry.category}</div>
                        <div class="entry-title">{stage.entry.title}</div>
                        <div class="entry-oneliner">{stage.entry.oneLiner}</div>
                      </div>
                      <div class="entry-arrow">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </div>
                    </a>
                  )}
                </div>
              </>
            );
          })}
        </>
      ) : (
        <>
          <div class="classic-intro">
            <Content />
          </div>

          <section>
            <h2 class="entries-heading">{type === 'pathway' ? 'The journey' : 'In this toolkit'}</h2>

            {type === 'pathway' ? (
              <ol class="pathway-list">
                {resolvedEntries.map((entry) => (
                  <li>
                    <a href={`/${entry.slug}/`} class="pathway-item">
                      <span class="pathway-number">{entry.index}</span>
                      <div class="pathway-content">
                        <span class="pathway-category" style={`color: ${categoryColours[entry.category] || '#8a7f72'}`}>
                          {entry.category}
                        </span>
                        <span class="pathway-title">{entry.title}</span>
                        <span class="pathway-oneliner">{entry.oneLiner}</span>
                      </div>
                    </a>
                  </li>
                ))}
              </ol>
            ) : (
              <div class="toolkit-grid">
                {resolvedEntries.map((entry) => (
                  <a href={`/${entry.slug}/`} class="toolkit-card">
                    <span class="toolkit-category" style={`color: ${categoryColours[entry.category] || '#8a7f72'}`}>
                      {entry.category}
                    </span>
                    <span class="toolkit-title">{entry.title}</span>
                    <span class="toolkit-oneliner">{entry.oneLiner}</span>
                  </a>
                ))}
              </div>
            )}
          </section>
        </>
      )}

      <div class="site-footer">
        <p>
          <a href="/">Moresapien</a> - Understanding ourselves, one idea at a time.
        </p>
      </div>
    </div>
  </body>
</html>
