---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Asterisk from '../../components/Asterisk.astro';
import { getCategoryColor } from '../../utils/categoryColors';

export async function getStaticPaths() {
  const collections = await getCollection('curatedCollections');
  return collections.map((collection) => ({
    params: { slug: collection.id },
    props: { collection },
  }));
}

const { collection } = Astro.props;
const { title, type, audience, collectionEntries } = collection.data;

const { Content } = await render(collection);

const allEntries = await getCollection('entries');
const resolvedEntries = collectionEntries.map((slug: string, index: number) => {
  const found = allEntries.find((e) => e.id === slug);
  return {
    slug,
    title: found ? found.data.title : slug,
    oneLiner: found ? found.data.oneLiner : '',
    category: found ? found.data.category : '',
    index: index + 1,
  };
});

const siteUrl = 'https://moresapien.org';
const pageUrl = siteUrl + '/collections/' + collection.id + '/';
const pageTitle = title + ' — Moresapien';
---
<BaseLayout
  title={pageTitle}
  description={audience}
  canonical={pageUrl}
>
  <Nav currentPage="collections" />

  <main id="main" class="collection-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/collections/">← All collections</a>
    </nav>

    <article class="collection">
      <header class="collection-header">
        <p class="eyebrow">{type === 'pathway' ? 'Learning pathway' : 'Toolkit'}</p>
        <h1 class="collection-title">
          <span>{title}</span>
          <span class="title-asterisk"><Asterisk size={28} /></span>
        </h1>
        <p class="collection-audience">{audience}</p>
      </header>

      <div class="collection-intro">
        <Content />
      </div>

      <section class="collection-entries">
        <h2 class="section-heading">{type === 'pathway' ? 'The journey' : 'In this toolkit'}</h2>

        {type === 'pathway' ? (
          <ol class="pathway-list">
            {resolvedEntries.map((entry) => (
              <li>
                <a
                  href={`/${entry.slug}/`}
                  class="pathway-item"
                  style={`--entry-accent: ${getCategoryColor(entry.category)};`}
                >
                  <span class="pathway-number">{String(entry.index).padStart(2, '0')}</span>
                  <div class="pathway-content">
                    <span class="pathway-category">{entry.category}</span>
                    <span class="pathway-title">
                      <span>{entry.title}</span>
                      <span class="entry-asterisk"><Asterisk size={11} color="var(--entry-accent)" /></span>
                    </span>
                    <span class="pathway-oneliner">{entry.oneLiner}</span>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <div class="toolkit-grid">
            {resolvedEntries.map((entry) => (
              <a
                href={`/${entry.slug}/`}
                class="toolkit-card"
                style={`--entry-accent: ${getCategoryColor(entry.category)};`}
              >
                <span class="toolkit-category">{entry.category}</span>
                <span class="toolkit-title">
                  <span>{entry.title}</span>
                  <span class="entry-asterisk"><Asterisk size={11} color="var(--entry-accent)" /></span>
                </span>
                <span class="toolkit-oneliner">{entry.oneLiner}</span>
              </a>
            ))}
          </div>
        )}
      </section>
    </article>
  </main>
</BaseLayout>

<style>
  .collection-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--ms-r6) var(--ms-r5) var(--ms-r9);
  }

  .breadcrumb {
    margin-bottom: var(--ms-r6);
  }

  .breadcrumb a {
    font-family: var(--ms-font-ui);
    font-size: 13px;
    color: var(--ms-mute);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--ms-coral);
  }

  .eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-coral);
    margin-bottom: var(--ms-r3);
  }

  .collection-header {
    margin-bottom: var(--ms-r7);
    padding-bottom: var(--ms-r6);
    border-bottom: 1px solid var(--ms-rule);
  }

  .collection-title {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h1);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--ms-ink);
    display: flex;
    align-items: baseline;
    gap: var(--ms-r2);
    flex-wrap: wrap;
    margin-bottom: var(--ms-r4);
  }
  .title-asterisk {
    display: inline-flex;
    align-self: baseline;
    transform: translateY(-0.55em);
  }
  .entry-asterisk {
    display: inline-flex;
    align-self: baseline;
    transform: translateY(-0.55em);
  }

  .collection-audience {
    font-family: var(--ms-font-body);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--ms-mute);
  }

  .collection-intro {
    margin-bottom: var(--ms-r8);
    max-width: 38rem;
  }

  .collection-intro :global(p) {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.65;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }

  .collection-intro :global(p:last-child) {
    margin-bottom: 0;
  }

  .collection-intro :global(em) {
    font-style: italic;
    color: var(--ms-coral);
  }

  .section-heading {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h3);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r5);
  }

  /* --- Pathway --- */
  .pathway-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r3);
  }

  .pathway-item {
    display: flex;
    align-items: flex-start;
    gap: var(--ms-r5);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-left: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: 0 var(--ms-radius-sm) var(--ms-radius-sm) 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pathway-item:hover {
    transform: translateX(2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .pathway-number {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    color: var(--entry-accent);
    letter-spacing: 0.1em;
    margin-top: 4px;
    flex-shrink: 0;
    min-width: 24px;
  }

  .pathway-content {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    min-width: 0;
  }

  .pathway-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .pathway-title {
    font-family: var(--ms-font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .pathway-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  /* --- Toolkit --- */
  .toolkit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--ms-r4);
  }

  .toolkit-card {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r2);
    padding: var(--ms-r5);
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-top: var(--ms-accent-rule-width) solid var(--entry-accent);
    border-radius: var(--ms-radius-sm);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .toolkit-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .toolkit-category {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
  }

  .toolkit-title {
    font-family: var(--ms-font-display);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-ink);
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .toolkit-oneliner {
    font-family: var(--ms-font-body);
    font-size: var(--ms-small);
    line-height: 1.55;
    color: var(--ms-mute);
  }

  @media (max-width: 640px) {
    .collection-page {
      padding: var(--ms-r5) var(--ms-r4) var(--ms-r8);
    }
    .pathway-item {
      padding: var(--ms-r4);
      gap: var(--ms-r3);
    }
    .toolkit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
