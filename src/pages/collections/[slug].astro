---
import { getCollection, render } from 'astro:content';
import Nav from '../../components/Nav.astro';

export async function getStaticPaths() {
  const collections = await getCollection('curatedCollections');
  return collections.map((collection) => ({
    params: { slug: collection.id },
    props: { collection },
  }));
}

const { collection } = Astro.props;
const { title, type, audience, collectionEntries, tags } = collection.data;

const { Content } = await render(collection);

const allEntries = await getCollection('entries');
const resolvedEntries = collectionEntries.map((slug, index) => {
  const found = allEntries.find((e) => e.id === slug);
  return {
    slug,
    title: found ? found.data.title : slug,
    oneLiner: found ? found.data.oneLiner : '',
    category: found ? found.data.category : '',
    index: index + 1,
  };
});

const categoryColours: Record<string, string> = {
  'Cognitive Bias': '#c17f59',
  'Logical Fallacy': '#7b8a6e',
  'Mental Model': '#5b7a8a',
  'Political Theory': '#8a6e7b',
  'Rhetorical Device': '#6e7b8a',
  'Systems Thinking': '#7a8a5b',
  'Manipulation Tactic': '#8b4a4a',
  'Psychological Phenomenon': '#7a6699',
  'Psychological Defence': '#4a7a7a',
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Moresapien</title>
    <meta name="description" content={audience} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Nunito:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <Nav currentPage="collections" />
    <div class="page-wrapper">
      <nav class="breadcrumb">
        <span class="collection-type-label">{type === 'pathway' ? 'Learning pathway' : 'Toolkit'}</span>
      </nav>

      <article class="collection">
        <header class="collection-header">
          <span class="type-badge">
            {type === 'pathway' ? 'Learning pathway' : 'Toolkit'}
          </span>
          <h1 class="collection-title">{title}</h1>
          <p class="collection-audience">{audience}</p>
        </header>

        <div class="collection-intro">
          <Content />
        </div>

        <section class="collection-entries">
          <h2>{type === 'pathway' ? 'The journey' : 'In this toolkit'}</h2>

          {type === 'pathway' ? (
            <ol class="pathway-list">
              {resolvedEntries.map((entry) => (
                <li>
                  <a href={`/${entry.slug}`} class="pathway-item">
                    <span class="pathway-number">{entry.index}</span>
                    <div class="pathway-content">
                      <span class="pathway-category" style={"color:" + (categoryColours[entry.category] || '#8a7f72')}>
                        {entry.category}
                      </span>
                      <span class="pathway-title">{entry.title}</span>
                      <span class="pathway-oneliner">{entry.oneLiner}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <div class="toolkit-grid">
              {resolvedEntries.map((entry) => (
                <a href={`/${entry.slug}`} class="toolkit-card">
                  <span class="toolkit-category" style={"color:" + (categoryColours[entry.category] || '#8a7f72')}>
                    {entry.category}
                  </span>
                  <span class="toolkit-title">{entry.title}</span>
                  <span class="toolkit-oneliner">{entry.oneLiner}</span>
                </a>
              ))}
            </div>
          )}
        </section>
      </article>

      <div class="site-footer">
        <p>
          <a href="/">Moresapien</a> - Understanding ourselves, one idea at a time.
        </p>
      </div>
    </div>

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Nunito', sans-serif;
        background: #faf8f5;
        color: #3a3530;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      .page-wrapper {
        max-width: 48rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        font-size: 0.875rem;
      }

      .collection-type-label {
        font-weight: 600;
        color: #C4622D;
      }

      .collection-header {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid #e8e0d8;
      }

      .type-badge {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #8a7f72;
        margin-bottom: 0.75rem;
      }

      .collection-title {
        font-family: 'Lora', serif;
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 700;
        color: #2a2520;
        line-height: 1.2;
        margin-bottom: 0.75rem;
      }

      .collection-audience {
        font-size: 1rem;
        color: #8a7f72;
        font-style: italic;
      }

      .collection-intro {
        margin-bottom: 3rem;
      }

      .collection-intro :global(p) {
        margin-bottom: 1rem;
        font-size: 1.05rem;
        line-height: 1.8;
      }

      .collection-entries h2 {
        font-family: 'Lora', serif;
        font-size: 1.375rem;
        font-weight: 600;
        color: #2a2520;
        margin-bottom: 1.5rem;
      }

      .pathway-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .pathway-item {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 0.75rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
      }

      .pathway-item:hover {
        border-color: #d0c8be;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transform: translateY(-1px);
      }

      .pathway-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 50%;
        background: #f5f0ea;
        color: #8a7f72;
        font-weight: 700;
        font-size: 0.875rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
      }

      .pathway-content {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .pathway-category {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .pathway-title {
        font-family: 'Lora', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: #2a2520;
      }

      .pathway-oneliner {
        font-size: 0.875rem;
        color: #8a7f72;
        line-height: 1.5;
      }

      .toolkit-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
        gap: 1rem;
      }

      .toolkit-card {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1.25rem;
        background: #fff;
        border: 1px solid #e8e0d8;
        border-radius: 0.75rem;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .toolkit-card:hover {
        border-color: #d0c8be;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transform: translateY(-1px);
      }

      .toolkit-category {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .toolkit-title {
        font-family: 'Lora', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: #2a2520;
      }

      .toolkit-oneliner {
        font-size: 0.85rem;
        color: #8a7f72;
        line-height: 1.5;
      }

      .site-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid #e8e0d8;
        text-align: center;
        font-size: 0.875rem;
        color: #a09888;
      }

      .site-footer a {
        color: #6a6058;
        text-decoration: none;
        font-weight: 600;
      }

      .site-footer a:hover {
        color: #C4622D;
      }

      @media (max-width: 640px) {
        .page-wrapper {
          padding: 1.5rem 1rem 3rem;
        }

        .pathway-item {
          padding: 1rem 1.25rem;
          gap: 1rem;
        }

        .toolkit-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
