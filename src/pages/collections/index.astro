---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Asterisk from '../../components/Asterisk.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import { getCategoryColor } from '../../utils/categoryColors';

const collections = await getCollection('curatedCollections');
const allEntries = await getCollection('entries');

const collectionsData = collections.map((col) => {
  const entryCount = col.data.collectionEntries.length;
  const firstSlug = col.data.collectionEntries[0];
  const firstEntry = allEntries.find((e) => e.id === firstSlug);
  const primaryCategory = firstEntry?.data.category ?? '';
  return {
    slug: col.id,
    title: col.data.title,
    audience: col.data.audience,
    entryCount,
    accent: primaryCategory ? getCategoryColor(primaryCategory) : 'var(--ms-mute)',
  };
});

const SITE = 'https://moresapien.org';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Collections - Moresapien',
  description:
    "Curated walks through Moresapien's knowledge base - guided journeys through cognitive biases, logical fallacies, manipulation tactics, and more.",
  url: SITE + '/collections/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Moresapien',
    url: SITE + '/',
  },
  hasPart: collectionsData.map((col) => ({
    '@type': 'CreativeWork',
    name: col.title,
    url: SITE + '/collections/' + col.slug + '/',
  })),
};
---
<BaseLayout
  title="Collections - Moresapien"
  description="Curated walks through Moresapien's knowledge base - guided journeys through cognitive biases, logical fallacies, manipulation tactics, and more."
  canonical="https://moresapien.org/collections/"
>
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(structuredData)}
  />

  <BreadcrumbSchema items={[
    { name: 'Home', url: 'https://moresapien.org/' },
    { name: 'Collections' },
  ]} />

  <Nav currentPage="collections" />

  <main id="main" class="collections-page">
    <header class="collections-header">
      <p class="eyebrow">Index</p>
      <h1 class="page-title">
        <span class="title-tail">Collections{' '}<span class="title-asterisk"><Asterisk size={28} /></span></span>
      </h1>
      <p class="page-deck">
        Each collection is a guided walk through one question - biases, tactics, and effects threaded into a single argument. Read in order, or jump in anywhere.
      </p>
    </header>

    <ol class="collections-index">
      {collectionsData.map((col, i) => (
        <li class="collection-item" style={`--entry-accent: ${col.accent};`}>
          <a href={`/collections/${col.slug}/`} class="collection-link">
            <span class="collection-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>

            <div class="collection-body">
              <h2 class="collection-title">{col.title}</h2>
              <p class="collection-deck">{col.audience}</p>
              <p class="collection-meta">
                {col.entryCount} concepts · Read →
              </p>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <p class="page-footer-note">
      <a href="/connections/">Explore the full knowledge graph →</a>
    </p>
  </main>

  <Footer />
</BaseLayout>

<style>
  .collections-page {
    max-width: 60rem;
    margin: 0 auto;
    padding: var(--ms-r7) var(--ms-r5) var(--ms-r9);
  }

  .collections-header {
    margin-bottom: var(--ms-r8);
  }

  .eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-coral);
    margin-bottom: var(--ms-r3);
  }

  .page-title {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h1);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }
  .title-tail {
    white-space: nowrap;
  }
  .title-asterisk {
    display: inline-block;
    transform: translateY(-0.55em);
  }

  .page-deck {
    font-family: var(--ms-font-body);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--ms-mute);
    max-width: 38rem;
  }

  /* --- Index --- */
  .collections-index {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .collection-item {
    border-top: 1px solid var(--ms-rule);
  }

  .collection-item:last-child {
    border-bottom: 1px solid var(--ms-rule);
  }

  .collection-link {
    display: grid;
    grid-template-columns: minmax(4rem, 6rem) minmax(0, 1fr);
    column-gap: var(--ms-r6);
    align-items: start;
    padding: var(--ms-r6) 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .collection-link:hover {
    transform: translateX(2px);
  }

  .collection-link:hover .collection-title {
    color: var(--entry-accent);
  }

  .collection-number {
    font-family: var(--ms-font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--entry-accent);
  }

  .collection-body {
    display: flex;
    flex-direction: column;
    gap: var(--ms-r3);
    max-width: 42rem;
  }

  .collection-title {
    font-family: var(--ms-font-display);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--ms-ink);
    margin: 0;
    transition: color 0.15s ease;
  }

  .collection-deck {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    line-height: 1.55;
    color: var(--ms-mute);
    margin: 0;
  }

  .collection-meta {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--entry-accent);
    margin: var(--ms-r2) 0 0;
  }

  /* --- Footer note --- */
  .page-footer-note {
    margin-top: var(--ms-r8);
    text-align: center;
  }

  .page-footer-note a {
    font-family: var(--ms-font-ui);
    font-size: 14px;
    color: var(--ms-coral);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.15s ease;
    text-decoration: none;
  }

  .page-footer-note a:hover {
    opacity: 0.75;
  }

  /* --- Responsive --- */
  @media (max-width: 720px) {
    .collections-page {
      padding: var(--ms-r5) var(--ms-r4) var(--ms-r8);
    }
    .collections-header {
      margin-bottom: var(--ms-r7);
    }
    .page-deck {
      font-size: 1rem;
    }
    .collection-link {
      grid-template-columns: 1fr;
      row-gap: var(--ms-r3);
      padding: var(--ms-r5) 0;
    }
    .collection-number {
      font-size: 3rem;
    }
  }
</style>
