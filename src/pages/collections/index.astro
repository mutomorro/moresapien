---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Asterisk from '../../components/Asterisk.astro';
import { getCategoryColor } from '../../utils/categoryColors';

const collections = await getCollection('curatedCollections');
const allEntries = await getCollection('entries');

const collectionsData = collections.map((col) => {
  const entryCount = col.data.collectionEntries.length;
  const resolvedEntries = col.data.collectionEntries.slice(0, 5).map((slug) => {
    const found = allEntries.find((e) => e.id === slug);
    return found ? { title: found.data.title, category: found.data.category } : null;
  }).filter(Boolean) as Array<{ title: string; category: string }>;

  return {
    slug: col.id,
    title: col.data.title,
    type: col.data.type,
    audience: col.data.audience,
    entryCount,
    categories: [...new Set(resolvedEntries.map((e) => e.category))],
  };
});
---
<BaseLayout
  title="Collections — Moresapien"
  description="Curated pathways through Moresapien's knowledge base. Guided journeys through cognitive biases, logical fallacies, manipulation tactics, and more."
  canonical="https://moresapien.org/collections/"
>
  <Nav currentPage="collections" />

  <main id="main" class="collections-page">
    <header class="collections-header">
      <p class="eyebrow">Curated pathways</p>
      <h1 class="page-title">
        Collections<span class="title-asterisk">{' '}<Asterisk size={28} /></span>
      </h1>
      <p class="page-intro">
        Each collection groups related concepts into a journey. Read in order, or browse freely — the connections show themselves either way.
      </p>
    </header>

    <ul class="collections-list">
      {collectionsData.map((col) => (
        <li>
          <a href={`/collections/${col.slug}/`} class="collection-card">
            <span
              class:list={['type-badge', col.type === 'pathway' ? 'badge-pathway' : 'badge-toolkit']}
            >
              {col.type === 'pathway' ? 'Pathway' : 'Toolkit'}
            </span>
            <h2 class="collection-title">{col.title}</h2>
            <p class="collection-audience">{col.audience}</p>
            <p class="collection-meta">
              {col.entryCount} {col.entryCount === 1 ? 'concept' : 'concepts'}
            </p>
            {col.categories.length > 0 && (
              <div class="category-row">
                {col.categories.map((cat) => (
                  <span class="category-dot" style={`--dot: ${getCategoryColor(cat)};`}>
                    <span class="dot" />{cat}
                  </span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>

    <p class="page-footer-note">
      <a href="/connections/">Explore the full knowledge graph →</a>
    </p>
  </main>

  <Footer />
</BaseLayout>

<style>
  .collections-page {
    max-width: 56rem;
    margin: 0 auto;
    padding: var(--ms-r7) var(--ms-r5) var(--ms-r9);
  }

  .collections-header {
    margin-bottom: var(--ms-r7);
  }

  .eyebrow {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
    margin-bottom: var(--ms-r3);
  }

  .page-title {
    font-family: var(--ms-font-display);
    font-size: var(--ms-h1);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--ms-ink);
    margin-bottom: var(--ms-r4);
  }
  .title-asterisk {
    display: inline-block;
    white-space: nowrap;
    transform: translateY(-0.55em);
  }

  .page-intro {
    font-family: var(--ms-font-body);
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--ms-mute);
    max-width: 38rem;
  }

  .collections-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ms-r4);
  }

  .collection-card {
    display: block;
    background: var(--ms-white);
    border: 1px solid var(--ms-rule);
    border-radius: var(--ms-radius-sm);
    padding: var(--ms-r5) var(--ms-r6);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .collection-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    border-color: var(--ms-coral);
  }

  .type-badge {
    display: inline-block;
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    border-radius: var(--ms-radius-pill);
    border: 1.5px solid currentColor;
  }

  .badge-pathway {
    color: var(--ms-coral);
  }

  .badge-toolkit {
    color: var(--ms-cat-systems);
  }

  .collection-title {
    font-family: var(--ms-font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--ms-ink);
    margin: var(--ms-r3) 0 var(--ms-r2);
  }

  .collection-audience {
    font-family: var(--ms-font-body);
    font-size: var(--ms-body);
    color: var(--ms-mute);
    line-height: 1.55;
    margin-bottom: var(--ms-r3);
  }

  .collection-meta {
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
  }

  .category-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ms-r3);
    margin-top: var(--ms-r3);
  }

  .category-dot {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--ms-font-mono);
    font-size: var(--ms-meta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ms-mute);
  }

  .category-dot .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot, var(--ms-mute));
    display: inline-block;
  }

  .page-footer-note {
    margin-top: var(--ms-r9);
    text-align: center;
  }

  .page-footer-note a {
    font-family: var(--ms-font-ui);
    font-size: 14px;
    color: var(--ms-coral);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.15s ease;
  }

  .page-footer-note a:hover {
    opacity: 0.75;
  }

  @media (max-width: 640px) {
    .collections-page {
      padding: var(--ms-r5) var(--ms-r4) var(--ms-r8);
    }
    .collection-card {
      padding: var(--ms-r4) var(--ms-r5);
    }
    .page-intro {
      font-size: 1rem;
    }
  }
</style>
